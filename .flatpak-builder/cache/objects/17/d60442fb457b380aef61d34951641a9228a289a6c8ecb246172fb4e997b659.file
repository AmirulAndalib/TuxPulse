[Application]
name=ro.eoliann.TuxPulse
runtime=org.kde.Platform/x86_64/6.6
sdk=org.kde.Sdk/x86_64/6.6
command=tuxpulse

[Context]
shared=network;ipc;
sockets=x11;wayland;
devices=dri;
filesystems=home;xdg-config/kdeglobals:ro;

[Session Bus Policy]
com.canonical.AppMenu.Registrar=talk
org.kde.kconfig.notify=talk
org.kde.KGlobalSettings=talk
