{
  "app-id": "ro.eoliann.TuxPulse",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.7",
  "sdk": "org.kde.Sdk",
  "command": "tuxpulse",
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=host",
    "--filesystem=/run/tuxpulse.sock"
  ],
  "modules": [
    {
      "name": "tuxpulse",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/share/tuxpulse",
        "cp -r app /app/share/tuxpulse/",
        "install -d /app/bin",
        "install -m755 packaging/deb/usr/bin/tuxpulse /app/bin/tuxpulse"
      ],
      "sources": [
        { "type": "dir", "path": ".." }
      ]
    }
  ]
}
